{
  "manifest_version": 3,
  "name": "Meesho Auto Lister",
  "version": "1.0.0",
  "description": "Auto-fill Meesho product listings using Gemini AI analysis",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://supplier.meesho.com/*",
    "https://ais-dev-clrnti3bzhacw6tpz7qw6w-47165258965.asia-east1.run.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://supplier.meesho.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
